#!/usr/bin/env -S java --source 25

import module java.base;

String name = MethodHandles.lookup().lookupClass().getName();
String version = "2026-07-21.2";

record BusinessComponent(Path path, List<String> layers) {

    static final Set<String> LAYERS = Set.of("boundary", "control", "entity");

    static BusinessComponent of(Path path) {
        try (var children = Files.list(path)) {
            return new BusinessComponent(path, layersOf(children));
        } catch (IOException notReadable) {
            return new BusinessComponent(path, List.of());
        }
    }

    static List<String> layersOf(Stream<Path> children) {
        return children
                .filter(Files::isDirectory)
                .map(child -> child.getFileName().toString())
                .filter(LAYERS::contains)
                .sorted()
                .toList();
    }

    boolean isComponent() {
        return !layers.isEmpty();
    }

    String describe(boolean full) {
        var display = full ? path.toAbsolutePath().normalize() : path.getFileName();
        return "%s [%s]".formatted(display, String.join(", ", layers));
    }
}

enum Log {

    COMPONENT("\033[38;2;42;161;152m");   // Solarized Cyan #2aa198

    private final String value;
    private static final String RESET = "\033[0m";

    Log(String color) {
        this.value = color + "%s" + RESET;
    }

    void out(String message) {
        System.out.println(this.value.formatted(message));
    }

    public static void component(String message) {
        Log.COMPONENT.out(message);
    }
}

List<BusinessComponent> findBusinessComponents(Path root) throws IOException {
    try (var tree = Files.walk(root)) {
        return tree
                .filter(Files::isDirectory)
                .map(BusinessComponent::of)
                .filter(BusinessComponent::isComponent)
                .sorted(Comparator.comparing(BusinessComponent::path))
                .toList();
    }
}

void main(String... args) throws Exception {
    IO.println(name + " " + version);
    var arguments = List.of(args);
    if (arguments.contains("-help")) {
        IO.println("""
                Usage: %s [directory] [-full]
                  Lists all business components (BCs) — directories
                  containing a boundary, control, or entity layer.
                  Defaults to the current directory.
                  -full  Show the complete path of each component
                  -help  Show this help
                """.formatted(name));
        return;
    }
    var full = arguments.contains("-full");
    var root = Path.of(arguments.stream()
            .filter(argument -> !argument.startsWith("-"))
            .findFirst()
            .orElse("."));
    if (!Files.isDirectory(root)) {
        System.err.println("Error: not a directory: " + root);
        System.exit(1);
    }
    var components = findBusinessComponents(root);
    if (components.isEmpty()) {
        System.err.println("No business components found in " + root);
        return;
    }
    components.forEach(bc -> Log.component(bc.describe(root, full)));
}
