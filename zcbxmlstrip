#!/usr/bin/env -S java --source 25

import module java.desktop;

import javax.xml.stream.XMLInputFactory;
import javax.xml.stream.XMLStreamConstants;
import javax.xml.stream.XMLStreamException;

/**
 * zcbxmlstrip - Zero dependencies Clipboard XML Strip
 *
 * Removes XML markup from the clipboard content and puts
 * the plain text back into the clipboard. Entities like
 * &amp; are decoded.
 *
 * Usage:
 *   zcbxmlstrip           strips XML markup from clipboard, in place
 *   zcbxmlstrip -trim     also trims whitespace and drops blank lines
 *   zcbxmlstrip -help     show this help
 *   zcbxmlstrip -version  show version
 *
 * Logging based on https://github.com/AdamBien/zcl
 */

String version = "2026-07-08.5";

static final String APP_NAME = "zcbxmlstrip";

void main(String... args) {
    Log.info(APP_NAME + " " + version);

    if (args.length > 0 && args[0].equals("-help")) {
        IO.println("Usage: " + APP_NAME + " [-trim]");
        IO.println("  Strips XML markup from clipboard text, in place");
        IO.println("  -trim       Also trim whitespace and drop blank lines");
        IO.println("  -help       Show this help");
        IO.println("  -version    Show version");
        return;
    }
    if (args.length > 0 && args[0].equals("-version"))
        return;

    var trim = args.length > 0 && args[0].equals("-trim");
    var content = clipboardContent();
    if (content.isBlank())
        Log.stop("Clipboard is empty");

    var stripped = stripMarkup(content, trim);
    toClipboard(stripped);

    Log.info("Markup stripped: %d -> %d chars".formatted(content.length(), stripped.length()));
}

String stripMarkup(String content, boolean trim) {
    var text = textOnly(content);
    return trim ? trimmed(text) : text;
}

String textOnly(String content) {
    try {
        return textContent(content);
    } catch (XMLStreamException e) {
        System.err.println("Not well-formed XML (" + e.getMessage() + "), falling back to tag removal");
        return content.replaceAll("<[^>]+>", "");
    }
}

String trimmed(String text) {
    return text.lines()
            .map(String::trim)
            .filter(line -> !line.isEmpty())
            .collect(Collectors.joining(System.lineSeparator()));
}

String textContent(String content) throws XMLStreamException {
    var factory = XMLInputFactory.newInstance();
    factory.setProperty(XMLInputFactory.SUPPORT_DTD, false);
    factory.setProperty(XMLInputFactory.IS_SUPPORTING_EXTERNAL_ENTITIES, false);

    var wrapped = "<z>" + content + "</z>";
    var reader = factory.createXMLStreamReader(new StringReader(wrapped));
    var text = new StringBuilder();
    while (reader.hasNext()) {
        var event = reader.next();
        if (event == XMLStreamConstants.CHARACTERS || event == XMLStreamConstants.CDATA) {
            text.append(reader.getText());
        }
    }
    return text.toString();
}

String clipboardContent() {
    try {
        var clipboard = Toolkit.getDefaultToolkit().getSystemClipboard();
        return (String) clipboard.getData(DataFlavor.stringFlavor);
    } catch (Exception e) {
        Log.stop("Failed to read clipboard: " + e.getMessage());
        return "";
    }
}

void toClipboard(String content) {
    var selection = new StringSelection(content);
    Toolkit.getDefaultToolkit().getSystemClipboard().setContents(selection, selection);
}

enum Log {

    ERROR(Color.BRIGHT_RED, System.err),
    INFO(Color.BRIGHT_GREEN, System.out);

    PrintStream out;

    enum Color {
        BRIGHT_RED("\033[38;5;196m"),
        BRIGHT_GREEN("\033[38;5;46m");

        String code;

        Color(String code) {
            this.code = code;
        }
    }

    String value;
    static final String RESET = "\033[0m";

    Log(Color color, PrintStream out) {
        this.value = color.code + "%s" + RESET;
        this.out = out;
    }

    void out(String message) {
        this.out.println(this.value.formatted(message));
    }

    static void info(String message) {
        INFO.out(message);
    }

    static void stop(String message) {
        ERROR.out(message);
        System.exit(1);
    }
}
