#!/usr/bin/env -S java --source 25

/**
 * zlaunch - Loads environment entries via zcfg, then launches an application.
 *
 * Configuration is loaded from (each overwrites the previous):
 *   1. $HOME/.zlaunch/app.properties  (global)
 *   2. ./app.properties               (local, current directory)
 *   3. -D system properties            (CLI overrides)
 *
 * All loaded properties become environment variables for the child process.
 *
 * Examples:
 *   zlaunch java -jar app.jar
 *   zlaunch -Ddb.url=prod:5432 java -jar app.jar
 *   zlaunch node server.js
 *
 * Configuration based on https://github.com/AdamBien/zcfg
 * Logging based on https://github.com/AdamBien/zcl
 */

String version = "2026-03-12.1";

static final String APP_NAME = "zlaunch";
static final String PROPERTIES_FILE = "app.properties";

Map<String, String> loadEntries() {
    ZCfg.load(APP_NAME);
    var systemKeys = System.getProperties().stringPropertyNames();
    return ZCfg.CACHE.stringPropertyNames().stream()
            .filter(key -> !systemKeys.contains(key))
            .collect(Collectors.toMap(
                    key -> key,
                    key -> ZCfg.string(key)));
}

void main(String... args) {
    if (args.length == 0 || args[0].equals("-help")) {
        IO.println("Usage: zlaunch <command> [args...]");
        IO.println("  -help     Show this help");
        IO.println("  -version  Show version");
        IO.println("");
        IO.println("Config sources (each overwrites previous):");
        IO.println("  $HOME/." + APP_NAME + "/" + PROPERTIES_FILE);
        IO.println("  ./" + PROPERTIES_FILE);
        IO.println("  -D flags (e.g., -Dkey=value)");
        return;
    }
    if (args[0].equals("-version")) {
        IO.println(APP_NAME + " " + version);
        return;
    }

    var entries = loadEntries();
    Log.info(APP_NAME + " " + version);

    if (entries.isEmpty()) {
        Log.warning("No entries found in " + PROPERTIES_FILE);
    } else {
        Log.info("Loaded " + entries.size() + " entries");
        entries.forEach((key, value) -> Log.user("  " + key + "=" + value));
    }

    var command = List.of(args);
    Log.info("Launching: " + String.join(" ", command));

    try {
        var process = new ProcessBuilder(command);
        process.environment().putAll(entries);
        var exitCode = process
                .inheritIO()
                .start()
                .waitFor();
        System.exit(exitCode);
    } catch (Exception e) {
        Log.stop("Failed to launch: " + e.getMessage());
    }
}

class ZCfg {

    static Properties CACHE;

    static void load(String appName) {
        CACHE = loadProperties(appName);
    }

    static Properties loadProperties(String appName) {
        var properties = new Properties();
        var userHome = System.getProperty("user.home");
        var globalConfig = Path.of(userHome, "." + appName, PROPERTIES_FILE);
        if (Files.exists(globalConfig))
            loadFromFile(globalConfig, properties);
        var localConfig = Path.of(PROPERTIES_FILE);
        if (Files.exists(localConfig))
            loadFromFile(localConfig, properties);
        properties.putAll(System.getProperties());
        return properties;
    }

    static void loadFromFile(Path file, Properties properties) {
        try (var reader = Files.newBufferedReader(file)) {
            properties.load(reader);
        } catch (IOException e) {
            Log.stop("Cannot load properties from: " + file + " (" + e.getMessage() + ")");
        }
    }

    static String string(String key) {
        return CACHE.getProperty(key);
    }

    static String string(String key, String defaultValue) {
        return CACHE.getProperty(key, defaultValue);
    }

    static int integer(String key, int defaultValue) {
        var value = CACHE.getProperty(key);
        return value != null ? Integer.parseInt(value) : defaultValue;
    }

    static boolean bool(String key, boolean defaultValue) {
        var value = CACHE.getProperty(key);
        return value != null ? Boolean.parseBoolean(value) : defaultValue;
    }

    static List<String> strings(String key) {
        var value = CACHE.getProperty(key);
        if (value == null)
            return List.of();
        return Stream.of(value.split(","))
                .map(String::trim)
                .toList();
    }
}

enum Log {

    ERROR(Color.BRIGHT_RED, System.err),
    USER(Color.BRIGHT_WHITE, System.out),
    INFO(Color.BRIGHT_GREEN, System.out),
    SYSTEM(Color.SKY_BLUE, System.out),
    WARNING(Color.WARM_YELLOW, System.out),
    DEBUG(Color.SOFT_PURPLE, System.out);

    PrintStream out;

    enum Color {
        WARM_YELLOW("\033[38;5;220m"),
        BRIGHT_WHITE("\033[38;5;255m"),
        BRIGHT_RED("\033[38;5;196m"),
        BRIGHT_GREEN("\033[38;5;46m"),
        SKY_BLUE("\033[38;5;39m"),
        SOFT_PURPLE("\033[38;5;129m");

        String code;

        Color(String code) {
            this.code = code;
        }
    }

    String value;
    static final String RESET = "\u001B[0m";

    Log(Color color, PrintStream out) {
        this.value = color.code + "%s" + RESET;
        this.out = out;
    }

    void out(String message) {
        this.out.println(this.value.formatted(message));
    }

    static void info(String message) {
        INFO.out(message);
    }

    static void user(String message) {
        USER.out(message);
    }

    static void warning(String message) {
        WARNING.out(message);
    }

    static void error(String message) {
        ERROR.out(message);
    }

    static void stop(String message) {
        error(message);
        System.exit(1);
    }
}
